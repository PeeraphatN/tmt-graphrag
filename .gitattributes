# Force LF in repo for cross-platform consistency
* text=auto eol=lf

# Binary file types — never normalize line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.bin binary
*.model binary
*.bpe.model binary
*.safetensors binary
*.pt binary
*.pth binary
*.onnx binary
*.pkl binary

# Generated / vendored — collapse in diffs
apps/web/package-lock.json -diff

# Linguist — exclude non-source HTML from language stats
# (otherwise GitHub reports this repo as "HTML" because a single
# 4.87 MB plotly dashboard outweighs all the Python source)
experiments/retrieval/retrieval_eval/results/**/*.html linguist-generated=true
experiments/retrieval/retrieval_eval/results/*.html   linguist-generated=true
experiments/**/docs/*.html                            linguist-documentation=true
docs/**/*.html                                        linguist-documentation=true
