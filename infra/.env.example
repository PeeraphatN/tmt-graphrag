# Neo4j Configuration
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here
NEO4J_AUTH=neo4j/your-secure-password-here

# Ollama Configuration
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings
LLM_MODEL=qwen2.5:7b-instruct
CLASSIFICATION_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=bge-m3:latest

# Vector Index Configuration
VECTOR_INDEX_NAME=tmt_embedding_index
FULLTEXT_INDEX_NAME=tmt_fulltext_index
EMBEDDING_DIM=1024

# GraphRAG Configuration
GRAPH_TRAVERSAL_DEPTH=2
NLEM_QA_ENABLED=false

# Intent V2 + NER Configuration
INTENT_V2_ENABLED=true
INTENT_V2_USE_NER=false
INTENT_V2_ADAPTIVE_PLANNER=true
INTENT_CENTROID_CACHE_ENABLED=true
INTENT_CENTROID_CACHE_DIR=cache/intent_classifier
NER_MODEL_DIR=artifacts/ner/final_model
NER_CONFIDENCE_THRESHOLD=0.60
NER_MAX_SEQ_LENGTH=128

# Request timeout for /chat endpoint in seconds (default: 120)
CHAT_TIMEOUT_SECONDS=120

# Reranker inference device: auto | cpu | cuda (default: auto)
# Set to cpu if VRAM is constrained (e.g. 8GB GPU shared with LLM)
RERANKER_DEVICE=auto
